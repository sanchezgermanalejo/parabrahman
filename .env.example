# Copiar como .env.local y reemplazar con los datos públicos de Supabase.
# Se encuentran en Supabase: Project Settings > API / Connect.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_reemplazar
# En producción, reemplazar por el dominio público definitivo.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Número público institucional con código de país, sin espacios ni símbolos.
# Ejemplo de formato argentino: 54911XXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=
